rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidProperty(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.price is number && data.price > 0
        && data.bhk is number && data.bhk > 0
        && data.location is string && data.location.size() <= 200
        && data.sector is string && data.sector.size() <= 200
        && data.city is string && data.city.size() <= 100
        && data.description is string && data.description.size() <= 2000
        && data.images is list && data.images.size() > 0 && data.images.size() <= 10
        && data.ownerId == request.auth.uid
        && data.createdAt == request.time;
    }

    match /properties/{propertyId} {
      allow list, get: if true;
      allow create: if isSignedIn() && isValidProperty(incoming()) && isValidId(propertyId);
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid 
        && isValidProperty(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isOwner(userId);
    }
  }
}
