{
  "entities": {
    "Property": {
      "title": "Property",
      "description": "Real estate listing object",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "bhk": { "type": "number" },
        "location": { "type": "string" },
        "sector": { "type": "string" },
        "city": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "bhk", "location", "sector", "city", "images", "ownerId", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "User favorite property link",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "propertyId", "createdAt"]
    }
  },
  "firestore": {
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Collection of all property listings"
    },
    "/users/{userId}/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "Subcollection of properties favorited by a user"
    }
  }
}
